{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{WORKSPACE_DIR}}/{{PROJECT_NAME}}/_system/hooks/log_user_prompt.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{WORKSPACE_DIR}}/{{PROJECT_NAME}}/_system/hooks/log_session_stop.sh"
          },
          {
            "type": "command",
            "command": "bash {{WORKSPACE_DIR}}/{{PROJECT_NAME}}/_system/hooks/auto_commit_push.sh"
          }
        ]
      }
    ]
  }
}
