__pycache__/
*.pyc
*.pyo
.env
.env.*
node_modules/
.DS_Store
*.log
.venv/
venv/

# ── Secrets — never commit ─────────────────────────────────────
.envrc
*.pem
*.key
*.p12
*.pfx
*.cert
secrets/
credentials/
**/.git_token
**/.env
**/.env.*
**/.envrc
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.cert
**/secrets/
**/credentials/

# ── Backend data (API keys, billing, user accounts) ───────────
ui/backend/data/

# ── _system: keep history/memory/context; ignore secrets+runtime ──
# Secrets inside _system
workspace/**/_system/.git_token

# Large Claude Code session transcripts (not needed in git)
workspace/**/_system/sessions/

# aicli CLI runtime data (session store, message history)
workspace/**/_system/aicli/sessions/
